# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# Google Gemini（Transcriber 多模態仲裁用，使用 Gemini 2.5 Pro）
GEMINI_API_KEY=

# xAI Grok（步驟 2 上線 2026-04-20；Sanji 走 Grok，跨 provider 路由見 shared/llm.py）
XAI_API_KEY=
# 選填，覆寫 endpoint；留空自動使用 https://api.x.ai/v1
XAI_BASE_URL=

# ── Per-agent model routing（選填，留空走 shared/llm_router.py 的 default） ──
# 優先序：MODEL_<AGENT>_<TASK> > MODEL_<AGENT> > DEFAULT_MODELS[task]
# TASK 目前有：DEFAULT（ask_claude / ask_claude_multi / shared.llm.ask）、
#              TOOL_USE（call_claude_with_tools）
# Provider 由 model ID prefix 自動判斷：claude-* → Anthropic、grok-* → xAI。
# 範例：
# MODEL_BROOK=claude-opus-4-7                  # Brook 長文寫作走 Opus
# MODEL_NAMI_TOOL_USE=claude-haiku-4-5         # Nami Slack bot tool routing 用 Haiku
# MODEL_SANJI=grok-4-fast-non-reasoning        # Sanji 社群口吻走 Grok fast tier
# MODEL_ROBIN=gemini-2.5-pro                   # Robin KB ingest 走 Gemini（步驟 4 起）

# Web UI
WEB_PASSWORD=your_password_here
WEB_SECRET=random_32_char_hex_string_here
DISABLE_ROBIN=              # VPS 設 1 停用 Robin（ingest + reader 僅本機）

# ── Franky Phase 1 monitoring（ADR-007）──
# Loopback URL for health_check.py 的 nakama_gateway probe。
# 留空走 http://127.0.0.1:8000/healthz（VPS 預設 gateway port）。
NAKAMA_HEALTHZ_URL=

# Franky Slack DM 目標（U07XXXXXXX；在 Slack channel 內 @自己 看 profile ID）。
# 同一變數也被 thousand_sunny/routers/bridge.py 用來 scope agent_memory 到修修本人。
SLACK_USER_ID_SHOSHO=

# Franky / shared.alerts Slack bot token（xoxb-...）。同一個 bot 同時供 Franky 健康
# alert 與 shared.alerts.alert(severity='error', ...) 使用。token 留空 → _NoopSlackStub
# 模式（log only），不會嘗試實際 DM — 適合 dev / CI。
SLACK_FRANKY_BOT_TOKEN=

# Phase 3 observability — log 輸出格式：text（預設、人類可讀）/ json（VPS 機器解析）
# VPS 設 json，dev / CI 維持 text。
NAKAMA_LOG_FORMAT=

# Phase 5C log search — 設 1 跳過 SQLite log sink（`/bridge/logs` 後端 FTS5 索引）。
# 一般 prod 不要設，cron / handler 自動寫進 `data/logs.db`。tests / CI 會在
# conftest 自動 setdefault=1 避免污染 dev DB。
NAKAMA_LOG_DB_DISABLE=

# R2（Cloudflare Object Storage）— Franky r2_backup_verify 讀取驗證。
# Franky 只驗備份，不寫入。R2_ACCOUNT_ID 用來組 endpoint：
#   https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# FRANKY_R2_PREFIX: 備份物件 prefix（例 "daily/"），留空代表整個 bucket
FRANKY_R2_PREFIX=
# FRANKY_R2_PREFIXES: 多個 prefix（CSV），每個獨立計算 consecutive-fail，分別發 alert。
# 必須是 R2 bucket 內**實際的 folder 路徑**，不是站名。xCloud 寫的 prefix 把 "." 換成 "-"：
#   ✘ shosho/,fleet/                    ← 站名，xCloud 並沒這樣寫
#   ✓ shosho-tw/,fleet-shosho-tw/       ← 對應 xcloud-backup bucket 實際 folder
# 設定漂移會讓 verify list 到 0 物件，連 N 日後 fire r2_backup_missing
# (2026-05-13 incident — PR #333 部署時設成站名，8 天才發現實際 folder 是站名-tw 格式)。
FRANKY_R2_PREFIXES=
# FRANKY_R2_STALE_HOURS: 超過此小時數視為 stale，預設 25（含 xCloud 1h buffer）
FRANKY_R2_STALE_HOURS=
# FRANKY_R2_MIN_SIZE_BYTES: 小於此視為 too_small，預設 1 MiB（防空壓縮檔）
FRANKY_R2_MIN_SIZE_BYTES=

# Nakama self-backup — scripts/backup_nakama_state.py 每日 04:00 snapshot state.db 到獨立 bucket。
# 獨立 bucket 是為了讓 Franky backup-verify 只看 xCloud 備份，不被 Nakama daily fresh 掩蓋 xCloud stale。
NAKAMA_R2_BACKUP_BUCKET=
# Mode-specific tokens（建議拆 read/write，舊單一 NAKAMA_R2_* 仍 fallback）：
# - mode='write'（backup script）lookup 順序：NAKAMA_R2_WRITE_* → NAKAMA_R2_* → R2_*
# - mode='read'（restore / integrity verify）：NAKAMA_R2_READ_* → NAKAMA_R2_* → R2_*
NAKAMA_R2_WRITE_ACCESS_KEY_ID=
NAKAMA_R2_WRITE_SECRET_ACCESS_KEY=
NAKAMA_R2_READ_ACCESS_KEY_ID=
NAKAMA_R2_READ_SECRET_ACCESS_KEY=
# Mode-agnostic fallback（既有部署沿用，新部署建議改走上面 mode-specific）
NAKAMA_R2_ACCESS_KEY_ID=
NAKAMA_R2_SECRET_ACCESS_KEY=
# Multi-tier retention（每天 04:00 cron 一次寫入 daily + Sundays 寫入 weekly + 月初寫入 monthly）。
# 註解放獨立行：dotenv inline `#` 會被當成 value 的一部分，crash int() coerce（feedback_env_example_formatting）。
# daily tier，預設 30
NAKAMA_BACKUP_RETENTION_DAYS=
# weekly tier（週日寫），預設 12
NAKAMA_BACKUP_WEEKLY_RETENTION_WEEKS=
# monthly tier（每月 1 號寫），預設 12
NAKAMA_BACKUP_MONTHLY_RETENTION_MONTHS=

# Backblaze B2 — secondary off-site mirror（vendor-redundancy 防 R2 整體失靈）。
# 開設步驟見 docs/runbooks/backup-secondary-setup.md。
# Mirror cron: 每日 04:30 Asia/Taipei 把當天 R2 snapshot mirror 到 B2。
# Verify cron: 每週日 03:30 跑 PRAGMA integrity_check 驗 R2 snapshot。
B2_BUCKET_NAME=
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_ENDPOINT_URL=
# Mirror tier 過濾（選填，CSV）— 預設 daily,weekly,monthly 全 mirror；
# 想省 B2 storage 改 "daily" 只保 freshest tier 的 vendor-redundancy。
NAKAMA_MIRROR_TIERS=
# 整合性驗證每 tier 採樣數（選填）：
NAKAMA_INTEGRITY_DAILY_SAMPLES=    # 預設 7
NAKAMA_INTEGRITY_WEEKLY_SAMPLES=   # 預設 4
NAKAMA_INTEGRITY_MONTHLY_SAMPLES=  # 預設 3

# ── Nami Gmail（與 Google Calendar 是不同帳號，共用同一個 Cloud Project）──
# 一次性授權：python scripts/google_gmail_auth.py（用 Gmail 帳號登入）
# Token 寫到 data/google_gmail_token.json，credentials 共用 data/google_oauth_credentials.json
# 部署到 VPS：scp data/google_gmail_token.json nakama-vps:/home/nakama/data/
# 詳細步驟見 docs/runbooks/nami-gmail-setup.md

# Email notification
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-password
NOTIFY_TO=your@email.com

# WordPress — per-site prefix (ADR-005b)
# Base URL is the WP site root; WordPressClient._request() appends `/wp-json/` internally.
# Primary site (Usopp publishes here):
WP_SHOSHO_BASE_URL=https://shosho.tw
WP_SHOSHO_USERNAME=bot_usopp
WP_SHOSHO_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
# Community site (Chopper, Phase 3):
WP_FLEET_BASE_URL=https://fleet.shosho.tw
WP_FLEET_USERNAME=bot_chopper
WP_FLEET_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# LiteSpeed cache purge method for Usopp (ADR-005b §5)
# 只接受 "noop"。Day 1 實測（2026-04-24）確認 WP save_post hook 自動 invalidate
# cache，explicit purge call 不需要；REST endpoint 不存在。舊值 rest / admin_ajax
# 會 fallback 到 noop 並記 WARNING。詳見 docs/runbooks/litespeed-purge.md。
LITESPEED_PURGE_METHOD=noop

# Usopp daemon tuning (all optional; safe defaults in agents/usopp/__main__.py)
# USOPP_TARGET_SITE: which WP_ prefix to publish to (wp_shosho | wp_fleet)
# USOPP_WORKER_ID: claim worker identity; defaults to usopp-<hostname>
# USOPP_POLL_INTERVAL_S: seconds between approval_queue poll ticks
# USOPP_BATCH_SIZE: rows per claim_approved_drafts() call
USOPP_TARGET_SITE=wp_shosho
USOPP_WORKER_ID=
USOPP_POLL_INTERVAL_S=30
USOPP_BATCH_SIZE=5

# YouTube (for Brook)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Twitter (for Zoro)
TWITTER_BEARER_TOKEN=

# Scout API keys
PUBMED_API_KEY=
# Unpaywall 全文查詢（Robin PubMed digest 用）
# 只是 API 的聯絡 email，不會 spam；留空會 fallback 到 NOTIFY_TO
UNPAYWALL_EMAIL=

# YouTube Data API (read-only, for Zoro keyword research)
YOUTUBE_API_KEY=

# Firecrawl (web scraping + SERP fetch)
# Used by: shared/firecrawl_search.py (Robin/Zoro source discovery),
#          shared/firecrawl_serp.py (seo-keyword-enrich Slice F SERP top-3 +
#                                    competitor_serp_summary).
# Free tier ~500 credits/month; SERP path = 1 search + 3 scrape per enrich.
FIRECRAWL_API_KEY=

# ── Slack Gateway (Socket Mode) ──
# 每個 agent 一個獨立 Slack app（各自 name / avatar / @mention）
# Runbook: docs/runbooks/add-agent-slack-bot.md
NAMI_SLACK_BOT_TOKEN=xoxb-xxx
NAMI_SLACK_APP_TOKEN=xapp-xxx

SANJI_SLACK_BOT_TOKEN=
SANJI_SLACK_APP_TOKEN=

ZORO_SLACK_BOT_TOKEN=
ZORO_SLACK_APP_TOKEN=
# Zoro brainstorm scout 推題目的 channel ID（#brainstorm）。留空 → scout 跑但不 publish。
ZORO_BRAINSTORM_CHANNEL_ID=

# 其他 agent 陸續上線（留空就不啟動對應 bot）
# BROOK_SLACK_BOT_TOKEN=
# BROOK_SLACK_APP_TOKEN=
# ROBIN_SLACK_BOT_TOKEN=
# ROBIN_SLACK_APP_TOKEN=
# CHOPPER_SLACK_BOT_TOKEN=
# CHOPPER_SLACK_APP_TOKEN=

# ── Auphonic (音頻前處理) ──

# 帳號（最多 5 個，格式：email,api_key）
AUPHONIC_ACCOUNT_1=user1@example.com,your_api_key_1
AUPHONIC_ACCOUNT_2=user2@example.com,your_api_key_2
AUPHONIC_ACCOUNT_3=
AUPHONIC_ACCOUNT_4=
AUPHONIC_ACCOUNT_5=

# Loudness normalization
AUPHONIC_LOUDNESS=-16          # LUFS 目標（Podcast: -16, YouTube: -14, Broadcast: -24）
AUPHONIC_LOUDNESS_METHOD=program  # program（整體）/ dialog（人聲）/ rms（Audible/ACX）
AUPHONIC_MAX_PEAK=auto         # 最大 True Peak（auto / -1dBTP / -2dBTP / -3dBTP）

# 降噪
AUPHONIC_DENOISE=true          # 啟用降噪
AUPHONIC_DENOISE_METHOD=dynamic   # classic / dynamic（推薦）/ static / speech_isolation
AUPHONIC_DENOISE_AMOUNT=0      # 降噪量 dB（0=自動, -1=關閉, 3-100）

# 去殘響 / 去呼吸聲
AUPHONIC_DEVERB_AMOUNT=-1      # 去殘響 dB（-1=關閉, 0=自動, 3-100）
AUPHONIC_DEBREATH_AMOUNT=-1    # 去呼吸聲 dB（-1=關閉, 3-100）

# 輸出格式
AUPHONIC_OUTPUT_FORMAT=wav     # wav / mp3 / flac / aac / opus
AUPHONIC_OUTPUT_BITDEPTH=24    # WAV bit depth（16 / 24 / 32）
AUPHONIC_OUTPUT_BITRATE=       # MP3/AAC bitrate（留空=optimal，或 128/192/256/320）

# Adaptive Leveler
AUPHONIC_LEVELER=true          # 啟用 adaptive leveler（平衡多人音量差異）
AUPHONIC_LEVELER_STRENGTH=100  # 0-120%（100=預設）
AUPHONIC_COMPRESSOR=auto       # auto / soft / medium / hard / off

# 濾波
AUPHONIC_FILTERING=true        # 啟用濾波
AUPHONIC_FILTER_METHOD=autoeq        # hipfilter（只高通）/ autoeq（voice EQ）/ bwe（頻寬擴展）

# 靜音 / 填充詞裁切
AUPHONIC_SILENCE_CUTTER=false  # 自動移除靜音段
AUPHONIC_FILLER_CUTTER=false   # 自動移除口頭禪（um, uh 等）

# Jingle 裁切（免費方案頭尾各加 6 秒 Jingle）
AUPHONIC_TRIM_JINGLE=true
AUPHONIC_JINGLE_SECONDS=6

# ── Google Cloud Platform（shared service account；setup §2 of setup-wp-integration-credentials.md）──
# 絕對路徑到 GCP service account JSON（同一份 sa 跨多 agent 共用）
# 既有 sa：nakama-franky@nakama-monitoring.iam.gserviceaccount.com
#   - 已授權 sc-domain:shosho.tw + sc-domain:fleet.shosho.tw 兩個 GSC property
#   - GA4 兩 property viewer
# 消費者：shared/gsc_client.py（ADR-009 SEO）+ 未來 Franky GSC/GA4 整合
GCP_SERVICE_ACCOUNT_JSON=

# ── ADR-009 SEO Solution / Google Search Console properties ──
# shosho.tw 的 GSC property 識別字串
# Domain property 用 "sc-domain:shosho.tw"；URL-prefix property 用 "https://shosho.tw/"
GSC_PROPERTY_SHOSHO=
# fleet.shosho.tw 的 GSC property
GSC_PROPERTY_FLEET=

# ── ADR-009 Phase 1.5 Slice D — PageSpeed Insights API ──
# Google PageSpeed Insights API key（免費 / 25k req/day quota）。
# Setup 步驟見 docs/runbooks/setup-wp-integration-credentials.md §2e。
# 消費者：shared/pagespeed_client.py（seo-audit-post skill 的 P1-P3 lab metric）
PAGESPEED_INSIGHTS_API_KEY=
