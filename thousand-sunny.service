[Unit]
Description=Nakama Thousand Sunny Web Server
After=network.target

[Service]
User=root
WorkingDirectory=/home/nakama
Environment="PYTHONPATH=/home/nakama"
EnvironmentFile=/home/nakama/.env
ExecStart=/usr/bin/python3 -m uvicorn thousand_sunny.app:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
